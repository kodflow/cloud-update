#!/bin/bash
# Pre-commit hook for cloud-update
# Quick checks before commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}═══════════════════════════════════════════${NC}"
echo -e "${BLUE}     🎯 Pre-Commit Quick Checks 🎯${NC}"
echo -e "${BLUE}═══════════════════════════════════════════${NC}"

# Get list of staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo -e "${YELLOW}▶ No Go files staged, skipping Go checks${NC}"
else
    echo -e "${YELLOW}▶ Checking staged Go files...${NC}"
    
    # Check Go formatting
    echo -e "${YELLOW}  • Checking formatting...${NC}"
    UNFORMATTED=$(gofmt -l $STAGED_GO_FILES 2>/dev/null || true)
    if [ -n "$UNFORMATTED" ]; then
        echo -e "${RED}  ✗ Go files need formatting:${NC}"
        echo "$UNFORMATTED" | sed 's/^/    /'
        echo -e "${YELLOW}  Run: gofmt -w $UNFORMATTED${NC}"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Go formatting OK${NC}"
    
    # Check for common issues
    echo -e "${YELLOW}  • Checking for common issues...${NC}"
    
    # Check for fmt.Print (should use logger or console package)
    # Skip test files and console package
    PRINT_ISSUES=""
    for file in $STAGED_GO_FILES; do
        # Skip test files, console package, and setup (CLI output)
        if [[ $file == *_test.go ]] || [[ $file == */console/* ]] || [[ $file == */setup/setup.go ]]; then
            continue
        fi
        
        # Find fmt.Print statements without nolint comment
        while IFS=: read -r line_num line_content; do
            if ! echo "$line_content" | grep -q "// nolint:fmt"; then
                PRINT_ISSUES="${PRINT_ISSUES}${file}:${line_num}: ${line_content}\n"
            fi
        done < <(grep -n "fmt\.Print" "$file" 2>/dev/null || true)
    done
    
    if [ -n "$PRINT_ISSUES" ]; then
        echo -e "${RED}  ✗ Found fmt.Print statements (use logger or console package)${NC}"
        echo -e "$PRINT_ISSUES" | head -5 | sed 's/^/    /'
        exit 1
    fi
    
    # Check for TODO comments
    TODOS=$(grep -n "TODO\|FIXME\|XXX" $STAGED_GO_FILES 2>/dev/null || true)
    if [ -n "$TODOS" ]; then
        echo -e "${YELLOW}  ⚠ Found TODO/FIXME comments:${NC}"
        echo "$TODOS" | head -3 | sed 's/^/    /'
    fi
    
    echo -e "${GREEN}  ✓ Go checks passed${NC}"
fi

# Get list of staged YAML/JSON files
STAGED_CONFIG_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(yml|yaml|json)$' || true)

if [ -n "$STAGED_CONFIG_FILES" ]; then
    echo -e "${YELLOW}▶ Checking config files...${NC}"
    
    # Validate YAML files (skip problematic ones)
    for file in $STAGED_CONFIG_FILES; do
        if [[ $file == *.yml ]] || [[ $file == *.yaml ]]; then
            # Skip problematic YAML files that have syntax issues with validators
            if [[ $file == .github/workflows/ci.yml ]] || [[ $file == .golangci.yml ]] || [[ $file == src/test/e2e/docker-compose.yml ]]; then
                continue
            fi
            if ! python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
                echo -e "${RED}  ✗ Invalid YAML: $file${NC}"
                exit 1
            fi
        fi
        
        # Validate JSON files
        if [[ $file == *.json ]]; then
            if ! python3 -m json.tool "$file" > /dev/null 2>&1; then
                echo -e "${RED}  ✗ Invalid JSON: $file${NC}"
                exit 1
            fi
        fi
    done
    echo -e "${GREEN}  ✓ Config files valid${NC}"
fi

# Check commit message format (if provided via .gitmessage)
if [ -f ".git/COMMIT_EDITMSG" ]; then
    COMMIT_MSG=$(cat .git/COMMIT_EDITMSG | head -1)
    
    # Check for conventional commit format
    if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+"; then
        echo -e "${YELLOW}  ⚠ Commit message doesn't follow conventional format${NC}"
        echo -e "${YELLOW}    Expected: type(scope): description${NC}"
        echo -e "${YELLOW}    Example: feat(api): add new endpoint${NC}"
    fi
fi

# Check file sizes
echo -e "${YELLOW}▶ Checking file sizes...${NC}"
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | xargs -I {} ls -la {} 2>/dev/null | awk '$5 > 1048576 {print $9 " (" $5 " bytes)"}')
if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}  ⚠ Large files detected (>1MB):${NC}"
    echo "$LARGE_FILES" | sed 's/^/    /'
fi

# Check for secrets/credentials
echo -e "${YELLOW}▶ Checking for secrets...${NC}"
# Skip setup.go as it legitimately generates secrets
PATTERNS="password|secret|token|apikey|api_key|private_key|aws_access|AKIA"
STAGED_NON_HOOK_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v "setup\.go\|\.githooks/" || true)
if [ -n "$STAGED_NON_HOOK_FILES" ]; then
    SECRETS=$(echo "$STAGED_NON_HOOK_FILES" | xargs grep -iE "$PATTERNS" 2>/dev/null | grep -v "^[^:]*test\.go:" | grep -v "\.md:" | grep -v "\.claude/agents/" | grep -v "CLOUD_UPDATE_SECRET\|HMAC.*secret\|cfg\.Secret\|E2E_SECRET.*test-secret-key-for-e2e\|GITHUB_TOKEN.*secrets\.GITHUB_TOKEN" || true)
else
    SECRETS=""
fi
if [ -n "$SECRETS" ]; then
    echo -e "${RED}  ✗ Possible secrets detected:${NC}"
    echo "$SECRETS" | head -3 | sed 's/^/    /'
    echo -e "${YELLOW}  Please review before committing${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ No secrets detected${NC}"

echo ""
echo -e "${GREEN}═══════════════════════════════════════════${NC}"
echo -e "${GREEN}      ✅ Pre-commit checks passed!${NC}"
echo -e "${GREEN}═══════════════════════════════════════════${NC}"

exit 0