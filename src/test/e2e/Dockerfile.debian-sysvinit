FROM debian:11

ENV DEBIAN_FRONTEND=noninteractive

# Install SysVInit and dependencies
RUN apt-get update && \
    apt-get install -y \
    sysvinit-core \
    sysvinit-utils \
    curl \
    ca-certificates \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Copy the pre-built binary and install script
WORKDIR /app
COPY dist/cloud-update_linux_amd64_v1/cloud-update /app/cloud-update
COPY scripts/install.sh /app/install.sh

# Make scripts executable
RUN chmod 755 /app/cloud-update /app/install.sh

# Set test environment variables
ENV CLOUD_UPDATE_SECRET=test-secret-key-for-e2e
ENV CLOUD_UPDATE_PORT=9999
ENV CLOUD_UPDATE_LOG_LEVEL=debug

# Run installation
RUN /app/install.sh

# Ensure service starts at boot
RUN update-rc.d cloud-update defaults

# Create init wrapper for container
RUN echo '#!/bin/bash' > /entrypoint.sh && \
    echo 'service cloud-update start' >> /entrypoint.sh && \
    echo 'tail -f /dev/null' >> /entrypoint.sh && \
    chmod +x /entrypoint.sh

# Health check
HEALTHCHECK --interval=5s --timeout=3s --start-period=30s --retries=5 \
    CMD curl -f http://localhost:9999/health || exit 1

EXPOSE 9999

# Start services
ENTRYPOINT ["/entrypoint.sh"]